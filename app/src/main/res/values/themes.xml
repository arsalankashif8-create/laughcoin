<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Laughcoin" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/cyber_dark</item>
        <item name="android:statusBarColor">@color/cyber_dark</item>
        <item name="android:navigationBarColor">@color/cyber_dark</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/cyber_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/laugh_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Laughcoin</item>
    </style>
</resources>